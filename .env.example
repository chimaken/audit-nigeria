# Copy to `.env` in the repo root (or `backend/.env`). Do not commit real secrets.

# =============================================================================
# Deployment order (AWS)
# =============================================================================
# Current Terraform outputs: S3 bucket, ECR, IAM policies — set AWS_* from outputs.
# These three you usually fill **after** RDS + API + frontend exist:
#   DATABASE_URL     — from Amazon RDS (endpoint, user, password, database name).
#   PUBLIC_BASE_URL  — public HTTPS URL of the FastAPI service (no trailing slash).
#   CORS_ALLOW_ORIGINS — comma-separated browser origins of your Next app (must match
#                        where users load the dashboard; same host you put in NEXT_PUBLIC_API_URL).
# =============================================================================

# --- Database ---
# Local Docker Compose / dev Postgres:
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/audit_nigeria
DASHBOARD_RESET_TOKEN=
# Amazon RDS for PostgreSQL: use the endpoint from RDS → Connectivity & security (port 5432).
# Scheme must be postgresql+asyncpg for this app. If RDS requires TLS, append ?ssl=require
# (or sslrootcert=... per AWS docs).
# DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASS@your-instance.xxxxx.eu-west-1.rds.amazonaws.com:5432/audit_nigeria?ssl=require

# --- Public API URL (proof links: {PUBLIC_BASE_URL}/files/...) ---
PUBLIC_BASE_URL=http://localhost:8000
# AWS:
# PUBLIC_BASE_URL=https://api.yourdomain.com

# --- Optional: reset collated votes from upload UI (POST /demo/reset-collated-votes) ---
# Long random string; send as X-Dashboard-Reset-Token. Leave empty to hide the CTA and return 404 for reset.
# DASHBOARD_RESET_TOKEN=

# --- OpenRouter (vision extraction on /upload when pu_id omitted) ---
# Create a key at https://openrouter.ai/keys — never commit real keys.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Must be a vision-capable slug from https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# When the photo is wider than tall, run vision on up to this many rotations (0°, 90°, 270°, …) and keep the best read. 1 = never spin (fastest).
# VISION_LANDSCAPE_ORIENTATION_TRIES=3

# --- AWS (S3 / region) ---
# Region for boto3 (S3, Bedrock). Matches Terraform `aws_region`.
AWS_REGION=eu-west-1
# Optional. `terraform output aws_account_id` — reference only; not a login credential.
AWS_ACCOUNT_ID=
# Terraform output `uploads_bucket_name` — leave empty locally to use disk uploads.
AWS_S3_BUCKET=

# Async uploads (presign → browser PUT → SQS → Lambda). Leave empty to use synchronous POST /upload only.
# When set with AWS_S3_BUCKET, GET /health exposes async_upload_enabled and POST /upload/async/* work.
# Terraform: output `upload_jobs_queue_url` when upload_async_pipeline_enabled is true.
# UPLOAD_JOBS_QUEUE_URL=
# Optional presigned PUT TTL (seconds); default 3600.
# UPLOAD_PRESIGN_EXPIRES_SECONDS=3600

USE_AWS_BEDROCK=false
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

CELERY_BROKER_URL=redis://localhost:6379/0

# Include error `type` + `message` in JSON on HTTP 500 (set false in production).
APP_EXPOSE_ERRORS=true

# --- CORS (browser → API) ---
# Local:
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS for the API when you run it locally (Docker / uvicorn). Hosted App Runner CORS is set in
# Terraform (`apprunner_cors_allow_origins` + automatic CloudFront origin when
# `frontend_cloudfront_enabled`). This line does not affect App Runner in AWS.
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# POST /upload optional JSON field `metadata`: use `expected_pu_code` or `gps.expected_pu_code`
# (INEC SS-LL-WW-UUU) to compare against the VLM-read code or the selected PU; mismatch flags
# `Geospatial Mismatch` and upload status `geospatial_mismatch_review`.
